# Normalize line endings to LF on checkout across all platforms.
# The repository already stores LF; this enforces it for Windows clones
# (overrides a global core.autocrlf=true) so prettier/eslint stay consistent.
* text=auto eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.keystore binary
*.jks   binary
